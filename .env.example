# Brokerage credentials and endpoints
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_SECRET=
TASTYTRADE_REFRESH=
TASTYTRADE_URL=https://api.tastyworks.com

# Safety: keep false until this host is intentionally allowed to place live orders.
LIVE_TRADING_ENABLED=false

# Safety: enables explicit user-initiated brokerage watchlist edits.
BROKERAGE_WATCHLIST_WRITES_ENABLED=false

# Market-data-pipeline API upstream used by the UI Research reverse proxy.
# Do not include a trailing slash.
RESEARCH_BACKEND_URL=http://192.168.50.248:8765

# Only needed when a development UI is served separately from the API.
CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200